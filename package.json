{
  "name": "omvra",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "overrides": {
    "shell-quote": "1.9.0",
    "form-data": "4.0.6",
    "undici": "6.27.0",
    "js-yaml": "4.3.0"
  },
  "main": "electron/main.cjs",
  "description": "A modern task management and planning tool",
  "author": "lorddarq",
  "scripts": {
    "dev:vite": "vite --port 5173",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:update": "OMVRA_DEBUG_UPDATE_STATUS=available OMVRA_DEBUG_UPDATE_VERSION=0.0.2 npm run dev",
    "dev:update:downloading": "OMVRA_DEBUG_UPDATE_STATUS=downloading OMVRA_DEBUG_UPDATE_VERSION=0.0.2 OMVRA_DEBUG_UPDATE_PROGRESS=42 npm run dev",
    "dev:update:downloaded": "OMVRA_DEBUG_UPDATE_STATUS=downloaded OMVRA_DEBUG_UPDATE_VERSION=0.0.2 OMVRA_DEBUG_UPDATE_PROGRESS=100 npm run dev",
    "dev:update:backup": "OMVRA_DEBUG_UPDATE_STATUS=available OMVRA_DEBUG_UPDATE_VERSION=0.0.2-rc.1 OMVRA_DEBUG_UPDATE_REQUIRES_BACKUP=1 npm run dev",
    "dev:pages": "vite --config pages/vite.config.ts",
    "build": "npm run build:renderer",
    "build:renderer": "vite build",
    "build:electron": "npm run build:renderer && node electron/scripts/build-electron-with-tag-version.cjs",
    "build:pages": "vite build --config pages/vite.config.ts",
    "test:hooks": "node --experimental-strip-types --experimental-specifier-resolution=node --test src/app/hooks/*.test.ts",
    "test:mcp": "node --test electron/services/workspace-service.test.cjs electron/services/mcp-http-server.test.cjs electron/services/mcp-fixtures.test.cjs electron/services/mcp-ipc.test.cjs electron/services/canonical-hydration.test.cjs electron/services/goal-state-service.test.cjs electron/services/goal-lifecycle-service.test.cjs electron/services/update-service.test.cjs electron/services/preload-update-bridge.test.cjs electron/services/update-ipc.test.cjs",
    "test:workspace-contracts": "npm run test:mcp && node --experimental-strip-types --experimental-specifier-resolution=node --test src/app/store/workspaceMutations.test.ts src/app/services/workspaceBackup.test.ts src/app/hooks/app-hooks.test.ts",
    "mcp:smoke": "node scripts/mcp-smoke-test.mjs",
    "workspace:diagnostics": "node electron/scripts/workspace-diagnostics.cjs",
    "workspace:export-diagnostics": "node electron/scripts/workspace-diagnostics.cjs --export /tmp/omvra-workspace-diagnostics.json",
    "workspace:export-store": "node electron/scripts/workspace-diagnostics.cjs --export-store /tmp/omvra-store-dev.json",
    "mcp:stdio": "node electron/scripts/mcp-stdio.cjs",
    "predist": "npm run generate:icons",
    "dist": "npm run predist && npm run build:electron",
    "start": "electron .",
    "generate:icons": "node electron/scripts/generate-icons.cjs"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-label": "2.1.2",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-slot": "1.1.2",
    "@radix-ui/react-switch": "1.3.1",
    "apca-w3": "^0.1.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/react": "^19.2.10",
    "@vitejs/plugin-react": "6.0.2",
    "concurrently": "^9.2.1",
    "electron": "39.8.10",
    "electron-builder": "^26.15.3",
    "icon-gen": "^2.1.0",
    "react-test-renderer": "^18.3.1",
    "sharp": "^0.35.3",
    "tailwindcss": "4.3.0",
    "typescript": "^5.9.3",
    "vite": "8.0.16",
    "wait-on": "^9.0.5"
  },
  "build": {
    "icon": "electron/assets/icon",
    "appId": "com.omvra.app",
    "productName": "Omvra",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "lorddarq",
      "repo": "omvra"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/skills",
        "to": "skills"
      }
    ],
    "mac": {
      "icon": "electron/assets/app.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "notarize": true
    },
    "dmg": {
      "background": "electron/assets/dmg-background.png"
    },
    "win": {
      "icon": "electron/assets/app.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "electron/assets/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
